@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using TaskFlow.Data

@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager
@inject IPasswordHasher<ApplicationUser> PasswordHasher
@inject NavigationManager NavigationManager

<PageTitle>Forgot your password?</PageTitle>

<div class="row">
    <div class="col-md-5">
        <h1 class="mb-1">Forgot your password?</h1>

        @if (step == 1)
        {
            <p class="text-muted mb-4">Enter your email and we'll show your security question.</p>

            @if (stepError != null)
            {
                <div class="alert alert-danger">@stepError</div>
            }

            <EditForm Model="emailModel" OnValidSubmit="LookUpUser">
                <DataAnnotationsValidator />
                <div class="form-floating mb-3">
                    <InputText @bind-Value="emailModel.Email" id="email" class="form-control"
                               autocomplete="username" placeholder="name@example.com" />
                    <label for="email">Email address</label>
                    <ValidationMessage For="() => emailModel.Email" class="text-danger" />
                </div>
                <button type="submit" class="w-100 btn btn-lg btn-primary">Continue</button>
            </EditForm>
        }

        @if (step == 2)
        {
            <p class="text-muted mb-4">Answer your security question to continue.</p>

            @if (stepError != null)
            {
                <div class="alert alert-danger">@stepError</div>
            }

            <div class="card mb-4 bg-light border-0 p-3">
                <p class="mb-0 fw-semibold">@securityQuestion</p>
            </div>

            <EditForm Model="answerModel" OnValidSubmit="VerifyAnswer">
                <DataAnnotationsValidator />
                <div class="form-floating mb-3">
                    <InputText @bind-Value="answerModel.Answer" id="answer" class="form-control"
                               autocomplete="off" placeholder="Your answer" />
                    <label for="answer">Your Answer</label>
                    <ValidationMessage For="() => answerModel.Answer" class="text-danger" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Verify Answer</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">Back</button>
                </div>
            </EditForm>
        }

        @if (step == 3)
        {
            <p class="text-muted mb-4">Choose a new password for your account.</p>

            @if (stepError != null)
            {
                <div class="alert alert-danger">@stepError</div>
            }

            <EditForm Model="passwordModel" OnValidSubmit="ResetPassword">
                <DataAnnotationsValidator />
                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="passwordModel.NewPassword" id="newpw"
                               class="form-control" autocomplete="new-password" placeholder="New password" />
                    <label for="newpw">New Password</label>
                    <ValidationMessage For="() => passwordModel.NewPassword" class="text-danger" />
                </div>
                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="passwordModel.ConfirmPassword" id="confirmpw"
                               class="form-control" autocomplete="new-password" placeholder="Confirm password" />
                    <label for="confirmpw">Confirm New Password</label>
                    <ValidationMessage For="() => passwordModel.ConfirmPassword" class="text-danger" />
                </div>
                <button type="submit" class="w-100 btn btn-lg btn-primary">Reset Password</button>
            </EditForm>
        }

        @if (step == 4)
        {
            <div class="text-center py-4">
                <div class="mb-3" style="font-size:2.5rem;">&#10003;</div>
                <h2 class="h4 mb-2">Password reset!</h2>
                <p class="text-muted mb-4">Your password has been updated. You can now log in.</p>
                <a href="/Account/Login" class="btn btn-primary">Go to Login</a>
            </div>
        }
    </div>
</div>

@code {
    private int step = 1;
    private string? stepError;

    // step 1
    private EmailModel emailModel = new();

    // step 2 — loaded after email lookup
    private string? securityQuestion;
    private string? foundUserId;
    private AnswerModel answerModel = new();

    // step 3
    private string? resetToken;
    private PasswordModel passwordModel = new();

    private async Task LookUpUser()
    {
        stepError = null;
        var user = await UserManager.FindByEmailAsync(emailModel.Email);

        // Always give same message to avoid user enumeration
        if (user == null || string.IsNullOrEmpty(user.SecurityQuestion))
        {
            stepError = "No account with a security question was found for that email.";
            return;
        }

        securityQuestion = user.SecurityQuestion;
        foundUserId = user.Id;
        step = 2;
    }

    private async Task VerifyAnswer()
    {
        stepError = null;
        var user = await UserManager.FindByIdAsync(foundUserId!);
        if (user == null || string.IsNullOrEmpty(user.SecurityAnswerHash))
        {
            stepError = "Something went wrong. Please start over.";
            step = 1;
            return;
        }

        var result = PasswordHasher.VerifyHashedPassword(
            user,
            user.SecurityAnswerHash,
            answerModel.Answer.Trim().ToLowerInvariant());

        if (result == PasswordVerificationResult.Failed)
        {
            stepError = "Incorrect answer. Please try again.";
            return;
        }

        resetToken = await UserManager.GeneratePasswordResetTokenAsync(user);
        step = 3;
    }

    private async Task ResetPassword()
    {
        stepError = null;
        var user = await UserManager.FindByIdAsync(foundUserId!);
        if (user == null || resetToken == null)
        {
            stepError = "Session expired. Please start over.";
            step = 1;
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, resetToken, passwordModel.NewPassword);
        if (!result.Succeeded)
        {
            stepError = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        step = 4;
    }

    private void GoBack()
    {
        stepError = null;
        step = 1;
    }

    // ── Models ──────────────────────────────────────────────

    private sealed class EmailModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }

    private sealed class AnswerModel
    {
        [Required(ErrorMessage = "Please enter your answer.")]
        public string Answer { get; set; } = "";
    }

    private sealed class PasswordModel
    {
        [Required]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters.")]
        [DataType(DataType.Password)]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("NewPassword", ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
