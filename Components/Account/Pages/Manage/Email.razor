@page "/Account/Manage/Email"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using TaskFlow.Data

@inject UserManager<ApplicationUser> UserManager
@inject IPasswordHasher<ApplicationUser> PasswordHasher
@inject IdentityUserAccessor UserAccessor
@inject NavigationManager NavigationManager

<PageTitle>Manage email</PageTitle>

<h3>Manage email</h3>

<StatusMessage Message="@message" />
<div class="row">
    <div class="col-xl-6">
        <EditForm Model="Input" FormName="change-email" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-floating mb-3">
                <input type="text" value="@email" id="current-email" class="form-control" disabled />
                <label for="current-email">Current email</label>
            </div>

            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.NewEmail" id="Input.NewEmail" class="form-control"
                           autocomplete="email" aria-required="true" placeholder="New Email" />
                <label for="Input.NewEmail">New email</label>
                <ValidationMessage For="() => Input.NewEmail" class="text-danger" />
            </div>

            @if (securityQuestion != null)
            {
                <div class="card bg-light border-0 p-3 mb-3">
                    <p class="mb-0 fw-semibold small">@securityQuestion</p>
                </div>
                <div class="form-floating mb-3">
                    <InputText @bind-Value="Input.SecurityAnswer" id="Input.SecurityAnswer"
                               class="form-control" autocomplete="off" placeholder="Your answer" />
                    <label for="Input.SecurityAnswer">Your Answer</label>
                    <ValidationMessage For="() => Input.SecurityAnswer" class="text-danger" />
                </div>
            }

            <button type="submit" class="w-100 btn btn-lg btn-primary">Change email</button>
        </EditForm>
    </div>
</div>

@code {
    private string? message;
    private string? email;
    private string? securityQuestion;
    private ApplicationUser user = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "change-email")]
    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        email = await UserManager.GetEmailAsync(user);
        securityQuestion = user.SecurityQuestion;
        Input.NewEmail ??= email;
    }

    private async Task OnValidSubmitAsync()
    {
        if (Input.NewEmail == email)
        {
            message = "Your email is unchanged.";
            return;
        }

        // Verify security answer if the account has one set
        if (!string.IsNullOrEmpty(user.SecurityAnswerHash))
        {
            if (string.IsNullOrWhiteSpace(Input.SecurityAnswer))
            {
                message = "Error: Please provide your security answer.";
                return;
            }

            var verification = PasswordHasher.VerifyHashedPassword(
                user,
                user.SecurityAnswerHash,
                Input.SecurityAnswer.Trim().ToLowerInvariant());

            if (verification == PasswordVerificationResult.Failed)
            {
                message = "Error: Incorrect security answer.";
                return;
            }
        }

        // Change email directly — no confirmation email needed
        var setEmailResult = await UserManager.SetEmailAsync(user, Input.NewEmail);
        if (!setEmailResult.Succeeded)
        {
            message = "Error: " + string.Join(", ", setEmailResult.Errors.Select(e => e.Description));
            return;
        }

        // Keep username in sync with email
        await UserManager.SetUserNameAsync(user, Input.NewEmail);

        message = "Your email has been updated.";
        email = Input.NewEmail;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        [Display(Name = "New email")]
        public string? NewEmail { get; set; }

        [Display(Name = "Security answer")]
        public string? SecurityAnswer { get; set; }
    }
}
