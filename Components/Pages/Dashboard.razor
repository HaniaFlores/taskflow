@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using TaskFlow.Data
@attribute [Authorize]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager

<PageTitle>My Tasks</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">My Tasks</h1>
        @if (!showForm)
        {
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ New Task</button>
        }
    </div>

    @if (showForm)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">@(editingTaskId == null ? "New Task" : "Edit Task")</h5>
                <EditForm Model="formModel" OnValidSubmit="SaveTask">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Title</label>
                        <InputText class="form-control" @bind-Value="formModel.Title" @oninput="e => titleLength = e.Value?.ToString()?.Length ?? 0" placeholder="Task title" maxlength="100" />
                        <div class="d-flex justify-content-between">
                            <ValidationMessage For="@(() => formModel.Title)" class="text-danger small" />
                            <small class="text-muted ms-auto">@titleLength/100</small>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description <span class="fw-normal text-muted">(optional)</span></label>
                        <InputTextArea class="form-control" @bind-Value="formModel.Description" @oninput="e => descLength = e.Value?.ToString()?.Length ?? 0" rows="2" placeholder="Add details..." maxlength="500" />
                        <small class="text-muted d-block text-end">@descLength/500</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <InputSelect class="form-select" @bind-Value="formModel.Category">
                            <option>Personal</option>
                            <option>Work</option>
                            <option>School</option>
                            <option>Health</option>
                            <option>Other</option>
                        </InputSelect>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (!showForm)
    {

    @if (tasks == null)
    {
        <p class="text-muted">Loading tasks...</p>
    }
    else if (tasks.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">No tasks yet.</p>
            <p>Click <strong>+ New Task</strong> to get started.</p>
        </div>
    }
    else
    {
        var pending   = tasks.Where(t => !t.IsCompleted).ToList();
        var completed = tasks.Where(t =>  t.IsCompleted).ToList();

        <!-- Pending -->
        <div class="d-flex justify-content-between align-items-center mb-2 mt-2">
            <h5 class="mb-0">Pending <span class="badge bg-primary ms-1">@pending.Count</span></h5>
            @if (pending.Count > 3)
            {
                <button class="btn btn-sm btn-outline-primary" @onclick="() => showAllPending = !showAllPending">
                    @(showAllPending ? "Show Less" : $"See All ({pending.Count})")
                </button>
            }
        </div>
        @if (pending.Count == 0)
        {
            <p class="text-muted small mb-4">No pending tasks.</p>
        }
        else
        {
            var visiblePending = showAllPending ? pending : pending.Take(3).ToList();
            <div class="list-group shadow-sm mb-4">
                @foreach (var task in visiblePending)
                {
                    <div @key="task.Id" class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3 @CategoryColor(task.Category)">
                        <input class="form-check-input mt-1 flex-shrink-0" type="checkbox"
                               checked="@task.IsCompleted"
                               @onchange="() => ToggleComplete(task.Id, task.IsCompleted)" />
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <span class="fw-semibold">@task.Title</span>
                                <span class="badge bg-secondary text-white flex-shrink-0">@task.Category</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <div class="small mt-1">
                                    @if (task.Description!.Length <= 200)
                                    {
                                        @task.Description
                                    }
                                    else if (expandedTasks.Contains(task.Id))
                                    {
                                        @task.Description
                                        <button class="btn btn-link btn-sm p-0 ms-1 text-primary" @onclick="() => ToggleExpand(task.Id)">See less</button>
                                    }
                                    else
                                    {
                                        @(task.Description!.Substring(0, 200))
                                        <span>... </span><button class="btn btn-link btn-sm p-0 text-primary" @onclick="() => ToggleExpand(task.Id)">See more</button>
                                    }
                                </div>
                            }
                            <div class="task-dates small mt-1">
                                <span>Created: @task.CreatedAt.ToString("MM/dd/yy h:mm tt")</span>
                            </div>
                        </div>
                        <div class="d-flex gap-1 flex-shrink-0">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(task)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Completed -->
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0">Completed <span class="badge bg-success ms-1">@completed.Count</span></h5>
            @if (completed.Count > 3)
            {
                <button class="btn btn-sm btn-outline-success" @onclick="() => showAllCompleted = !showAllCompleted">
                    @(showAllCompleted ? "Show Less" : $"See All ({completed.Count})")
                </button>
            }
        </div>
        @if (completed.Count == 0)
        {
            <p class="text-muted small">No completed tasks yet.</p>
        }
        else
        {
            var visibleCompleted = showAllCompleted ? completed : completed.Take(3).ToList();
            <div class="list-group shadow-sm">
                @foreach (var task in visibleCompleted)
                {
                    <div @key="task.Id" class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3 bg-light">
                        <input class="form-check-input mt-1 flex-shrink-0" type="checkbox"
                               checked="@task.IsCompleted"
                               @onchange="() => ToggleComplete(task.Id, task.IsCompleted)" />
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <span class="text-decoration-line-through text-muted">@task.Title</span>
                                <span class="badge bg-secondary text-white flex-shrink-0">@task.Category</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <div class="small mt-1">
                                    @if (task.Description!.Length <= 200)
                                    {
                                        @task.Description
                                    }
                                    else if (expandedTasks.Contains(task.Id))
                                    {
                                        @task.Description
                                        <button class="btn btn-link btn-sm p-0 ms-1 text-primary" @onclick="() => ToggleExpand(task.Id)">See less</button>
                                    }
                                    else
                                    {
                                        @(task.Description!.Substring(0, 200))
                                        <span>... </span><button class="btn btn-link btn-sm p-0 text-primary" @onclick="() => ToggleExpand(task.Id)">See more</button>
                                    }
                                </div>
                            }
                            <div class="task-dates small mt-1">
                                <span>Created: @task.CreatedAt.ToString("MM/dd/yy h:mm tt")</span>
                                @if (task.CompletedAt.HasValue)
                                {
                                    <span>Completed: @task.CompletedAt.Value.ToString("MM/dd/yy h:mm tt")</span>
                                }
                            </div>
                        </div>
                        <div class="d-flex gap-1 flex-shrink-0">
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
        }
    }

    } @* end @if (!showForm) *@
</div>

@code {
    private List<TaskItem>? tasks;
    private bool showForm;
    private int? editingTaskId;
    private TaskFormModel formModel = new();
    private string? currentUserId;
    private HashSet<int> expandedTasks = new();
    private int titleLength;
    private int descLength;
    private bool showAllPending;
    private bool showAllCompleted;

    private void ToggleExpand(int taskId)
    {
        if (!expandedTasks.Add(taskId))
            expandedTasks.Remove(taskId);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        currentUserId = user?.Id;
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        if (currentUserId == null) return;
        tasks = await Db.TaskItems
            .Where(t => t.UserId == currentUserId)
            .OrderByDescending(t => t.Id)
            .AsNoTracking()
            .ToListAsync();
    }

    private void ShowCreateForm()
    {
        editingTaskId = null;
        formModel = new TaskFormModel();
        titleLength = 0;
        descLength = 0;
        showForm = true;
    }

    private void StartEdit(TaskItem task)
    {
        editingTaskId = task.Id;
        formModel = new TaskFormModel
        {
            Title = task.Title,
            Description = task.Description,
            Category = task.Category
        };
        titleLength = task.Title?.Length ?? 0;
        descLength = task.Description?.Length ?? 0;
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingTaskId = null;
    }

    private async Task SaveTask()
    {
        if (currentUserId == null) return;

        if (editingTaskId == null)
        {
            var newTask = new TaskItem
            {
                Title = formModel.Title,
                Description = formModel.Description,
                Category = formModel.Category,
                UserId = currentUserId,
                CreatedAt = DateTime.Now
            };
            Db.TaskItems.Add(newTask);
        }
        else
        {
            var existing = await Db.TaskItems.FindAsync(editingTaskId);
            if (existing != null && existing.UserId == currentUserId)
            {
                existing.Title = formModel.Title;
                existing.Description = formModel.Description;
                existing.Category = formModel.Category;
            }
        }

        await Db.SaveChangesAsync();
        showForm = false;
        editingTaskId = null;
        await LoadTasks();
    }

    private async Task ToggleComplete(int taskId, bool currentValue)
    {
        var task = await Db.TaskItems.FindAsync(taskId);
        if (task != null && task.UserId == currentUserId)
        {
            task.IsCompleted = !currentValue;
            task.CompletedAt = task.IsCompleted ? DateTime.Now : null;
            await Db.SaveChangesAsync();
        }
        await LoadTasks();
    }

    private async Task DeleteTask(int taskId)
    {
        var task = await Db.TaskItems.FindAsync(taskId);
        if (task != null && task.UserId == currentUserId)
        {
            Db.TaskItems.Remove(task);
            await Db.SaveChangesAsync();
        }
        await LoadTasks();
    }

    private static string CategoryColor(string category) => category switch
    {
        "Work"     => "task-work",
        "School"   => "task-school",
        "Health"   => "task-health",
        "Personal" => "task-personal",
        _          => "task-other"
    };

    private class TaskFormModel
    {
        [Required(ErrorMessage = "Title is required")]
        [StringLength(100, ErrorMessage = "Title must be 100 characters or less")]
        public string Title { get; set; } = string.Empty;

        [StringLength(500)]
        public string? Description { get; set; }

        public string Category { get; set; } = "Personal";
    }
}
