@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using TaskFlow.Data
@attribute [Authorize]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager

<PageTitle>My Tasks</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">My Tasks</h1>
        @if (!showForm)
        {
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ New Task</button>
        }
    </div>

    @if (showForm)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">@(editingTaskId == null ? "New Task" : "Edit Task")</h5>
                <EditForm Model="formModel" OnValidSubmit="SaveTask">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Title</label>
                        <InputText class="form-control" @bind-Value="formModel.Title" placeholder="Task title" />
                        <ValidationMessage For="@(() => formModel.Title)" class="text-danger small" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description <span class="fw-normal text-muted">(optional)</span></label>
                        <InputTextArea class="form-control" @bind-Value="formModel.Description" rows="2" placeholder="Add details..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <InputSelect class="form-select" @bind-Value="formModel.Category">
                            <option>Personal</option>
                            <option>Work</option>
                            <option>School</option>
                            <option>Health</option>
                            <option>Other</option>
                        </InputSelect>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (!showForm)
    {

    @if (tasks == null)
    {
        <p class="text-muted">Loading tasks...</p>
    }
    else if (tasks.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">No tasks yet.</p>
            <p>Click <strong>+ New Task</strong> to get started.</p>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var task in tasks)
            {
                <div class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3 @(task.IsCompleted ? "bg-light" : CategoryColor(task.Category))">
                    <input class="form-check-input mt-1 flex-shrink-0" type="checkbox"
                           checked="@task.IsCompleted"
                           @onchange="() => ToggleComplete(task.Id, task.IsCompleted)" />
                    <div class="flex-grow-1 min-width-0">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "fw-semibold")">
                                @task.Title
                            </span>
                            <span class="badge bg-secondary text-white flex-shrink-0">@task.Category</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <div class="text-muted small mt-1">@task.Description</div>
                        }
                        <div class="text-muted small mt-1">
                            Created: @task.CreatedAt.ToString("MMM d, yyyy h:mm tt")
                            @if (task.CompletedAt.HasValue)
                            {
                                <span class="ms-3">Completed: @task.CompletedAt.Value.ToString("MMM d, yyyy h:mm tt")</span>
                            }
                        </div>
                    </div>
                    <div class="d-flex gap-1 flex-shrink-0">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(task)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    }

    } @* end @if (!showForm) *@
</div>

@code {
    private List<TaskItem>? tasks;
    private bool showForm;
    private int? editingTaskId;
    private TaskFormModel formModel = new();
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        currentUserId = user?.Id;
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        if (currentUserId == null) return;
        tasks = await Db.TaskItems
            .Where(t => t.UserId == currentUserId)
            .OrderByDescending(t => t.Id)
            .AsNoTracking()
            .ToListAsync();
    }

    private void ShowCreateForm()
    {
        editingTaskId = null;
        formModel = new TaskFormModel();
        showForm = true;
    }

    private void StartEdit(TaskItem task)
    {
        editingTaskId = task.Id;
        formModel = new TaskFormModel
        {
            Title = task.Title,
            Description = task.Description,
            Category = task.Category
        };
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingTaskId = null;
    }

    private async Task SaveTask()
    {
        if (currentUserId == null) return;

        if (editingTaskId == null)
        {
            var newTask = new TaskItem
            {
                Title = formModel.Title,
                Description = formModel.Description,
                Category = formModel.Category,
                UserId = currentUserId,
                CreatedAt = DateTime.Now
            };
            Db.TaskItems.Add(newTask);
        }
        else
        {
            var existing = await Db.TaskItems.FindAsync(editingTaskId);
            if (existing != null && existing.UserId == currentUserId)
            {
                existing.Title = formModel.Title;
                existing.Description = formModel.Description;
                existing.Category = formModel.Category;
            }
        }

        await Db.SaveChangesAsync();
        showForm = false;
        editingTaskId = null;
        await LoadTasks();
    }

    private async Task ToggleComplete(int taskId, bool currentValue)
    {
        var task = await Db.TaskItems.FindAsync(taskId);
        if (task != null && task.UserId == currentUserId)
        {
            task.IsCompleted = !currentValue;
            task.CompletedAt = task.IsCompleted ? DateTime.Now : null;
            await Db.SaveChangesAsync();
        }
        await LoadTasks();
    }

    private async Task DeleteTask(int taskId)
    {
        var task = await Db.TaskItems.FindAsync(taskId);
        if (task != null && task.UserId == currentUserId)
        {
            Db.TaskItems.Remove(task);
            await Db.SaveChangesAsync();
        }
        await LoadTasks();
    }

    private static string CategoryColor(string category) => category switch
    {
        "Work"     => "task-work",
        "School"   => "task-school",
        "Health"   => "task-health",
        "Personal" => "task-personal",
        _          => "task-other"
    };

    private class TaskFormModel
    {
        [Required(ErrorMessage = "Title is required")]
        [StringLength(100, ErrorMessage = "Title must be 100 characters or less")]
        public string Title { get; set; } = string.Empty;

        public string? Description { get; set; }

        public string Category { get; set; } = "Personal";
    }
}
